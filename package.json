{
    "name": "proxydbq",
    "productName": "Proxy DBQ",
    "version": "0.0.1",
    "description": "This tool provides a real-time list of all SQL queries, monitoring and automatically analyzing them to determine whether they use a database index.",
    "main": "src/index.js",
    "type": "module",
    "scripts": {
        "dev": "cross-env NODE_ENV=development vite",
        "build": "vite build && electron-builder",
        "preview": "vite preview",
        "package": "vite build && electron-builder --dir --config.npmRebuild=false",
        "package:ia32": "vite build && electron-builder --dir --ia32 --config.npmRebuild=false",
        "build:win": "vite build && electron-builder --win",
        "build:mac": "vite build && electron-builder --mac",
        "build:linux": "vite build && electron-builder --linux",
        "build:all": "vite build && electron-builder -mwl",
        "test": "cross-env NODE_ENV=test playwright test"
    },
    "resolutions": {
        "vue-template-compiler": "npm:@vue/compiler-sfc@^3.5.16"
    },
    "build": {
        "appId": "com.proxydbq.app",
        "productName": "Proxy DBQ",
        "directories": {
            "output": "dist"
        },
        "artifactName": "${productName}-${os}-${arch}.${ext}",
        "files": [
            "dist/**/*",
            "dist-electron/**/*",
            "src/**/*"
        ],
        "win": {
            "target": [
                "nsis",
                "portable",
                "zip"
            ],
            "icon": "build/icon.ico"
        },
        "mac": {
            "target": [
                "dmg",
                "zip"
            ],
            "icon": "build/icon.icns"
        },
        "linux": {
            "target": [
                "AppImage",
                "deb",
                "rpm",
                "tar.gz"
            ],
            "icon": "build/icon.png",
            "category": "Development"
        }
    },
    "dependencies": {
        "@popperjs/core": "^2.11.8",
        "bootstrap": "^5.3.6",
        "bootstrap-icons": "^1.13.1",
        "electron-squirrel-startup": "^1.0.1",
        "highlight.js": "^11.11.1",
        "mysql2": "^3.14.3",
        "pinia": "^3.0.3",
        "vue": "^3.5.16",
        "xxhash-addon": "^2.1.0"
    },
    "devDependencies": {
        "@electron-forge/cli": "^7.11.1",
        "@electron-forge/maker-squirrel": "^7.11.1",
        "@electron-forge/maker-zip": "^7.11.1",
        "@electron-forge/plugin-vite": "^7.11.1",
        "@playwright/test": "^1.52.0",
        "@vitejs/plugin-vue": "^5.2.1",
        "@vue/compiler-sfc": "^3.5.16",
        "cross-env": "^7.0.3",
        "electron": "^41.2.1",
        "electron-builder": "^26.0.12",
        "playwright": "^1.52.0",
        "rollup": "^4.30.0",
        "sass": "^1.89.1",
        "vite": "^6.1.0",
        "vite-plugin-electron": "^0.29.0",
        "vite-plugin-electron-renderer": "^0.14.6"
    },
    "config": {
        "forge": "./forge.config.mjs"
    },
    "overrides": {
        "esbuild": "0.21.5"
    }
}
